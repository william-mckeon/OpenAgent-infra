# =============================================================================
# .env.example  (project root)
#
# Safe template for .env — committed to the repo.
# Copy this file to .env and fill in real values before running.
#
#   cp .env.example .env
#
# All variable names here match exactly the os.environ.get() calls in
# src/api/main.py: API_KEY, BASE_MODEL_URL, NERVOUS_SYSTEM_URL,
# EMBEDDING_MODEL_URL, PROVIDER_API_KEY, REASONING_EFFORT, BASE_MODEL_NAME,
# NERVOUS_SYSTEM_MODEL_NAME, EMBEDDING_MODEL_NAME — and the ENV defaults in
# docker/model/Dockerfile.
#
# openagent-infra runs on port 8002.
# Port 8001 is reserved for openagent-api; port 8000 for openagent-frontend.
# Topology: openagent-api (:8001) → openagent-infra (:8002) → BYOC provider
#           The provider routes to:
#             base model            ← /chat default,  model="base"
#             nervous-system model  ← /chat optional, model="nervous_system"
#             embedding model       ← /embed (EMBEDDING_MODEL_URL)
# =============================================================================

# -----------------------------------------------------------------------------
# API_KEY
# Secret required on every POST /chat and POST /embed request via the
# X-API-Key header. Requests with a missing or incorrect key receive 401
# Unauthorized. openagent-api — and any other server-side caller — must send
# this key with every request. It is the same value openagent-api holds as
# INFRA_API_KEY (the names differ across the boundary; the values must match
# byte-for-byte).
# Use a long random string — at minimum 32 characters.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: never commit your real key — only this placeholder is safe.
# -----------------------------------------------------------------------------
API_KEY=your_api_key_here_minimum_32_characters

# -----------------------------------------------------------------------------
# BASE_MODEL_URL
# OpenAI-compatible BASE endpoint for the base model — the primary reasoning
# model, and the provider root WITHOUT the chat-completions path. The proxy
# appends /v1/chat/completions when forwarding a /chat request, and /health
# probes this bare base URL directly. All /chat requests route here by default
# (model="base"). Required.
#   e.g. https://your-provider.com/openai
#
# This is BYOC (Bring Your Own Compute) — point it at any OpenAI-compatible
# endpoint: a managed API, a self-hosted vLLM/Ollama runtime, or a serverless
# host (e.g. RunPod, whose endpoints expose the base at <endpoint>/openai).
#
# IMPORTANT: never commit your real endpoint URL — only this placeholder is safe.
# -----------------------------------------------------------------------------
BASE_MODEL_URL=https://your-provider.com/openai

# -----------------------------------------------------------------------------
# BASE_MODEL_NAME
# Optional model name for the base route. When set, the proxy adds
# "model": <name> to the payload it forwards for model="base" /chat requests.
# When empty, no model field is sent (the default, original behavior).
#
# Set this ONLY if your base endpoint requires an explicit model field. Many
# single-model endpoints serve a fixed model and need no name — leave it empty
# in that case. Routing is by URL regardless; this only controls the payload.
# -----------------------------------------------------------------------------
BASE_MODEL_NAME=

# -----------------------------------------------------------------------------
# NERVOUS_SYSTEM_URL
# OpenAI-compatible BASE endpoint for the nervous-system (control-layer) model
# — the fast, lightweight model for routing, history filtering, and agent
# decisions. Same base form as BASE_MODEL_URL (no /v1/chat/completions — the
# proxy appends it). Used when model="nervous_system" is passed in the /chat
# request body.
#
# Optional. If not set, requests with model="nervous_system" fail gracefully
# and the pipeline is unbroken — omitting the model field always routes to the
# base model.
#
# IMPORTANT: never commit your real endpoint URL — only this placeholder is safe.
# -----------------------------------------------------------------------------
NERVOUS_SYSTEM_URL=https://your-provider.com/openai

# -----------------------------------------------------------------------------
# NERVOUS_SYSTEM_MODEL_NAME
# Optional model name for the nervous-system route. Same behavior as
# BASE_MODEL_NAME, for model="nervous_system" /chat requests. When empty, no
# model field is sent. Set only if that endpoint requires an explicit model
# field.
# -----------------------------------------------------------------------------
NERVOUS_SYSTEM_MODEL_NAME=

# -----------------------------------------------------------------------------
# EMBEDDING_MODEL_URL
# OpenAI-compatible BASE endpoint for the embedding model — same base form as
# BASE_MODEL_URL (no path — the proxy appends /v1/embeddings). Used by POST
# /embed to turn text into vectors (e.g. for conversation-history retrieval).
#
# Optional. If not set, /embed returns a clear "not configured" error and the
# /chat path is entirely unaffected.
#
# IMPORTANT: never commit your real endpoint URL — only this placeholder is safe.
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_URL=https://your-provider.com/openai

# -----------------------------------------------------------------------------
# EMBEDDING_MODEL_NAME
# Optional model name for the embedding route. When set, the proxy adds
# "model": <name> to the /embed payload. When empty, no model field is sent.
#
# NOTE: many OpenAI-compatible embedding runtimes REQUIRE this field and return
# 500 without it (BGE-M3 is one — set EMBEDDING_MODEL_NAME=BAAI/bge-m3). If
# /embed returns 502 with an upstream 500, a missing model name is the likely
# cause. Set this to the model id your embedding endpoint serves.
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=

# -----------------------------------------------------------------------------
# PROVIDER_API_KEY
# Provider credential sent as the Authorization: Bearer header on every request
# forwarded to the provider endpoint(s) (base, nervous-system, and embedding).
# Separate from API_KEY, which faces the caller — this key faces the provider
# and is never exposed to any caller.
#
# IMPORTANT: never commit your real key — only this placeholder is safe.
# -----------------------------------------------------------------------------
PROVIDER_API_KEY=your_provider_api_key_here

# -----------------------------------------------------------------------------
# REASONING_EFFORT
# Default reasoning effort level if not set per request.
# The FastAPI proxy injects this into the system message automatically.
# Applies to both chat models (base and nervous-system); the embedding model
# does not reason. openagent-api or any tooling can override per request in the
# request body.
#
# Options:
#   low    — fast responses, minimal reasoning chain
#             Use for: lightweight tooling calls, simple lookups, routing
#   medium — balanced reasoning (default)
#             Use for: standard interactions, general questions
#   high   — deep reasoning, extended chain-of-thought
#             Use for: complex analysis, multi-step reasoning, hard problems
# -----------------------------------------------------------------------------
REASONING_EFFORT=medium
