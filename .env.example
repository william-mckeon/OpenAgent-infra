# =============================================================================
# .env.example  (project root)
#
# Safe template for .env — committed to the repo.
# Copy this file to .env and fill in real values before running.
#
#   cp .env.example .env
#
# All variable names here match exactly the os.environ.get() calls in
# src/api/main.py: API_KEY, BASE_MODEL_URL, NERVOUS_SYSTEM_URL,
# PROVIDER_API_KEY, REASONING_EFFORT — and the ENV defaults in
# docker/model/Dockerfile.
#
# openagent-infra runs on port 8002.
# Port 8001 is reserved for openagent-api; port 8000 for openagent-frontend.
# Topology: openagent-api (:8001) → openagent-infra (:8002) → BYOC provider
#           The provider routes to:
#             base model            ← default, model="base"
#             nervous-system model  ← optional, model="nervous_system"
# =============================================================================

# -----------------------------------------------------------------------------
# API_KEY
# Secret required on every POST /chat request via the X-API-Key header.
# Requests with a missing or incorrect key receive 401 Unauthorized.
# openagent-api must send this key with every request — it is the same value
# openagent-api holds as INFRA_API_KEY (the names differ across the boundary;
# the values must match byte-for-byte).
# Use a long random string — at minimum 32 characters.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: never commit your real key — only this placeholder is safe.
# -----------------------------------------------------------------------------
API_KEY=your_api_key_here_minimum_32_characters

# -----------------------------------------------------------------------------
# BASE_MODEL_URL
# Full OpenAI-compatible chat-completions endpoint for the base model — the
# primary reasoning model. All /chat requests route here by default. The proxy
# POSTs to this URL directly (it does not modify the path), so provide the
# complete endpoint, e.g.:
#   https://your-provider.com/v1/chat/completions
#
# This is BYOC (Bring Your Own Compute) — point it at any OpenAI-compatible
# endpoint: a managed API, a self-hosted vLLM/Ollama runtime, or a serverless
# host (e.g. RunPod). openagent-infra does not care which.
#
# IMPORTANT: never commit your real endpoint URL — only this placeholder is safe.
# -----------------------------------------------------------------------------
BASE_MODEL_URL=https://your-provider.com/v1/chat/completions

# -----------------------------------------------------------------------------
# NERVOUS_SYSTEM_URL
# Full OpenAI-compatible chat-completions endpoint for the nervous-system
# (control-layer) model — the fast, lightweight model for routing, history
# filtering, and agent decisions. Used when model="nervous_system" is passed
# in the /chat request body.
#
# Optional. If not set, requests with model="nervous_system" fail gracefully
# and the pipeline is unbroken — omitting the model field always routes to the
# base model. Same full-URL format as BASE_MODEL_URL.
#
# IMPORTANT: never commit your real endpoint URL — only this placeholder is safe.
# -----------------------------------------------------------------------------
NERVOUS_SYSTEM_URL=https://your-provider.com/v1/chat/completions

# -----------------------------------------------------------------------------
# PROVIDER_API_KEY
# Provider credential sent as the Authorization: Bearer header on every request
# forwarded to the provider endpoint(s) (base and nervous-system).
# Separate from API_KEY, which faces the caller — this key faces the provider
# and is never exposed to any caller.
#
# IMPORTANT: never commit your real key — only this placeholder is safe.
# -----------------------------------------------------------------------------
PROVIDER_API_KEY=your_provider_api_key_here

# -----------------------------------------------------------------------------
# REASONING_EFFORT
# Default reasoning effort level if not set per request.
# The FastAPI proxy injects this into the system message automatically.
# Applies to both the base model and the nervous-system model.
# openagent-api or any tooling can override per request in the request body.
#
# Options:
#   low    — fast responses, minimal reasoning chain
#             Use for: lightweight tooling calls, simple lookups, routing
#   medium — balanced reasoning (default)
#             Use for: standard interactions, general questions
#   high   — deep reasoning, extended chain-of-thought
#             Use for: complex analysis, multi-step reasoning, hard problems
# -----------------------------------------------------------------------------
REASONING_EFFORT=medium
