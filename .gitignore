# =============================================================================
# .gitignore  (project root)
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets — .env must never be committed
# Use .env.example (which is committed) as the safe template
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Model weights — defensive exclusion.
# No weights live in this repo (inference runs at the provider); this keeps any
# accidental local /models/ directory out of version control.
# -----------------------------------------------------------------------------
/models/

# -----------------------------------------------------------------------------
# Python cache and build artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Editor and OS files
# -----------------------------------------------------------------------------
.DS_Store
*.swp
*.swo
.vscode/
.idea/
Thumbs.db

# -----------------------------------------------------------------------------
# Test and CI artifacts
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
